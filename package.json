{
  "name": "@qrcommunication/withallo-sdk",
  "version": "0.2.2",
  "description": "TypeScript SDK for Withallo (Allo) API — webhooks, calls, contacts, SMS and phone numbers. Isomorphic core + optional React hooks.",
  "keywords": [
    "withallo",
    "allo",
    "sms",
    "webhooks",
    "calls",
    "contacts",
    "sdk",
    "api",
    "typescript",
    "react"
  ],
  "homepage": "https://github.com/QrCommunication/sdk-withallo-js",
  "bugs": {
    "url": "https://github.com/QrCommunication/sdk-withallo-js/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QrCommunication/sdk-withallo-js.git"
  },
  "license": "MIT",
  "author": {
    "name": "QrCommunication",
    "email": "contact@qrcommunication.com",
    "url": "https://qrcommunication.com"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\"",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.17.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
